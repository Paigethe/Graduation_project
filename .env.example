# Docker compose / Backend common env (示例)

# MySQL (Docker)
MYSQL_ROOT_PASSWORD=bs001_root_pw
MYSQL_DATABASE=bs001_psycare
MYSQL_USER=bs001_user
MYSQL_PASSWORD=bs001_pass

# Backend
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_HOST=127.0.0.1
DB_PORT=52518
DB_NAME=bs001_psycare
DB_USER=bs001_user
DB_PASSWORD=bs001_pass

REDIS_HOST=127.0.0.1
REDIS_PORT=52519
USE_REDIS_CACHE=1

# Message encryption (Fernet key, dev-only)
# 生成命令：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MESSAGE_ENCRYPTION_KEY=eDlQVzqLFiU1vCkFlLPr0BEcZcXqTNy1yfOuTd9Hpw8=

# AI chat (OpenAI-compatible endpoint)
DEEPSEEK_BASE_URL=https://media.apiport.cc.cd/v1
DEEPSEEK_MODEL=grok-4.1-fast
DEEPSEEK_API_KEY=

# Risk model inference (optional). When disabled or files missing, predictor uses placeholder.
RISK_MODEL_ENABLED=0
RISK_MODEL_PATH=./storage/models/risk/model.joblib
RISK_MODEL_META_PATH=./storage/models/risk/model_meta.json
RISK_MODEL_VERSION=risk_model_bridge_v1

# High-risk student dormant-login alert threshold (days)
DORMANT_RISK_DAYS=14
